{
  "name": "@atmo-dev/contrail",
  "version": "0.2.0",
  "description": "Index AT Protocol records with typed XRPC endpoints. Cloudflare Workers + D1, SvelteKit, Node.js.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./sqlite": {
      "types": "./dist/adapters/sqlite.d.ts",
      "import": "./dist/adapters/sqlite.js"
    },
    "./postgres": {
      "types": "./dist/adapters/postgres.d.ts",
      "import": "./dist/adapters/postgres.js"
    },
    "./workers": {
      "types": "./dist/workers/backfill.d.ts",
      "import": "./dist/workers/backfill.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    },
    "./cli-config": {
      "types": "./dist/cli-config.d.ts",
      "import": "./dist/cli-config.js"
    }
  },
  "bin": {
    "contrail": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flo-bit/contrail.git",
    "directory": "packages/contrail"
  },
  "keywords": [
    "atproto",
    "bluesky",
    "cloudflare",
    "d1",
    "indexer",
    "xrpc"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@atcute/atproto": "^3.1.10",
    "@atcute/cid": "^2.4.1",
    "@atcute/client": "^4.2.1",
    "@atcute/identity": "^1.1.4",
    "@atcute/identity-resolver": "^1.2.2",
    "@atcute/jetstream": "^1.0.2",
    "@atcute/lexicons": "^1.2.9",
    "@atcute/xrpc-server": "^0.1.12",
    "hono": "^4.12.8",
    "jiti": "^2.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250124.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.63.0"
  },
  "peerDependencies": {
    "pg": "^8.0.0",
    "wrangler": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "wrangler": {
      "optional": true
    }
  },
  "license": "MIT"
}

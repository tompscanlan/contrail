{
  "lexicon": 1,
  "id": "tools.atmo.space.refreshCredential",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Refresh an unexpired space credential. The current credential must verify and the bearer must still be a member. Returns a fresh credential (same scope, same sub, same space) with a new expiry. No service-auth JWT required — the credential itself is the authentication.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["credential"],
          "properties": {
            "credential": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["credential", "expiresAt"],
          "properties": {
            "credential": { "type": "string" },
            "expiresAt": { "type": "integer" }
          }
        }
      },
      "errors": [
        { "name": "InvalidRequest" },
        { "name": "InvalidCredential" },
        { "name": "NotFound" },
        { "name": "Forbidden" },
        { "name": "NotImplemented" }
      ]
    }
  }
}

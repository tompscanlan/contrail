{
	"name": "contrail",
	"main": "src/worker.ts",
	"compatibility_date": "2025-12-25",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "contrail",
			"database_id": "YOUR_DATABASE_ID"
		}
	],
	"triggers": {
		"crons": [
			"*/1 * * * *"
		]
	}
}

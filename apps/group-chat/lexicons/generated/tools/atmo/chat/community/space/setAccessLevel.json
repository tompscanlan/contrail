{
  "lexicon": 1,
  "id": "tools.atmo.chat.community.space.setAccessLevel",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Change the access level of an existing grant. Caller must outrank both the old and new level.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "spaceUri",
            "subject",
            "accessLevel"
          ],
          "properties": {
            "spaceUri": {
              "type": "string",
              "format": "at-uri"
            },
            "subject": {
              "type": "ref",
              "ref": "tools.atmo.chat.community.defs#subject"
            },
            "accessLevel": {
              "type": "ref",
              "ref": "tools.atmo.chat.community.defs#accessLevel"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "ok"
          ],
          "properties": {
            "ok": {
              "type": "boolean"
            }
          }
        }
      },
      "errors": [
        {
          "name": "InvalidRequest"
        },
        {
          "name": "NotFound"
        },
        {
          "name": "Forbidden"
        }
      ]
    }
  }
}

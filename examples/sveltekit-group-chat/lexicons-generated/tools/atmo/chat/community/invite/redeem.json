{
  "lexicon": 1,
  "id": "tools.atmo.chat.community.invite.redeem",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Redeem a community invite. The caller's DID (from service-auth) is granted the access level encoded in the invite. Atomic — a token is consumed only if the invite is currently usable.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "token"
          ],
          "properties": {
            "token": {
              "type": "string"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "spaceUri",
            "accessLevel",
            "communityDid"
          ],
          "properties": {
            "spaceUri": {
              "type": "string",
              "format": "at-uri"
            },
            "accessLevel": {
              "type": "ref",
              "ref": "tools.atmo.chat.community.defs#accessLevel"
            },
            "communityDid": {
              "type": "string",
              "format": "did"
            }
          }
        }
      },
      "errors": [
        {
          "name": "InvalidRequest"
        },
        {
          "name": "InvalidToken"
        },
        {
          "name": "NotFound"
        }
      ]
    }
  }
}

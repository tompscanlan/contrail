{
  "lexicon": 1,
  "id": "rsvp.atmo.space.invite.redeem",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Redeem an invite token. The JWT issuer becomes a member of the space with the invite's perms.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "token"
          ],
          "properties": {
            "token": {
              "type": "string"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "spaceUri",
            "perms"
          ],
          "properties": {
            "spaceUri": {
              "type": "string",
              "format": "at-uri"
            },
            "perms": {
              "type": "string",
              "knownValues": [
                "read",
                "write"
              ]
            }
          }
        }
      },
      "errors": [
        {
          "name": "InvalidInvite"
        }
      ]
    }
  }
}

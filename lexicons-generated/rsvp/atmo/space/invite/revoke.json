{
  "lexicon": 1,
  "id": "rsvp.atmo.space.invite.revoke",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Revoke an invite. Owner only. Invites are identified by their tokenHash (visible in list output).",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "spaceUri",
            "tokenHash"
          ],
          "properties": {
            "spaceUri": {
              "type": "string",
              "format": "at-uri"
            },
            "tokenHash": {
              "type": "string"
            }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "ok"
          ],
          "properties": {
            "ok": {
              "type": "boolean"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound"
        },
        {
          "name": "Forbidden"
        }
      ]
    }
  }
}

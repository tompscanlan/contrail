{
  "lexicon": 1,
  "id": "tools.atmo.space.invite.redeem",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Redeem an invite token. The JWT issuer becomes a member of the space.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["token"],
          "properties": {
            "token": { "type": "string" }
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["spaceUri"],
          "properties": {
            "spaceUri": { "type": "string", "format": "at-uri" }
          }
        }
      },
      "errors": [
        { "name": "InvalidInvite" }
      ]
    }
  }
}
